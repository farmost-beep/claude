.container{padding:16px}.header{text-align:center;padding:25px 0 15px}.title{font-size:26px;font-weight:bold;color:#1A2744}.subtitle{display:block;font-size:14px;color:#666;margin-top:4px}
.stats-row{display:flex;justify-content:space-around;background:#f0f4ff;border-radius:12px;padding:14px;margin:10px 0}
.stat{text-align:center}.stat-num{font-size:22px;font-weight:bold;color:#1A2744;display:block}.stat-label{font-size:12px;color:#666;display:block;margin-top:2px}
.quick-actions{display:flex;gap:8px;margin:10px 0}.qa-btn{flex:1;background:#f0f4ff;border-radius:14px;padding:14px;text-align:center}
.qa-icon{font-size:28px;display:block}.qa-text{font-size:15px;font-weight:bold;color:#1A2744;display:block;margin-top:4px}
.qa-sub{font-size:11px;color:#999;display:block;margin-top:2px}
.section{margin:16px 0}.section-title{font-size:17px;font-weight:bold;color:#1A2744}.section-desc{display:block;font-size:13px;color:#999;margin:2px 0 12px}
.form{background:#f8f9fa;border-radius:12px;padding:14px}.label{font-size:14px;font-weight:500;color:#333;display:block;margin:10px 0 6px}
.options{display:flex;flex-wrap:wrap;gap:8px}
.option{background:#fff;border:1px solid #ddd;border-radius:20px;padding:6px 14px;font-size:14px;color:#555}
.option.active{background:#1A2744;color:#fff;border-color:#1A2744}
.input{width:100%;height:44px;background:#fff;border:1px solid #ddd;border-radius:8px;padding:10px 12px;font-size:15px;box-sizing:border-box;margin-top:4px;color:#333}
.btn{width:100%;padding:14px;background:#1A2744;color:#fff;border:none;border-radius:8px;font-size:16px;text-align:center;margin-top:14px}
.btn[disabled]{background:#ccc}
