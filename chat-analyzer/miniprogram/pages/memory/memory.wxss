.container{padding:16px}.header{text-align:center;padding:20px 0}
.title{font-size:22px;font-weight:bold;color:#1A2744}.subtitle{display:block;font-size:13px;color:#999;margin-top:4px}
.upload-card{background:linear-gradient(135deg,#8B5CF6,#EC4899);border-radius:16px;padding:24px;text-align:center;margin:10px 0;color:#fff}
.upload-icon{font-size:40px;display:block}.upload-text{font-size:18px;font-weight:bold;display:block;margin-top:4px}
.upload-sub{font-size:13px;opacity:0.8;display:block;margin-top:2px}
.stats-row{display:flex;justify-content:space-around;background:#f0f4ff;border-radius:12px;padding:14px;margin:10px 0}
.stat{text-align:center}.stat-num{font-size:24px;font-weight:bold;color:#1A2744;display:block}.stat-label{font-size:12px;color:#666;display:block}
.section-title{font-size:16px;font-weight:bold;color:#1A2744;margin:16px 0 8px}
.empty{text-align:center;padding:40px 0}.empty-text{display:block;font-size:16px;color:#333}.empty-sub{display:block;font-size:13px;color:#999;margin-top:4px}
.memory-card{background:#fff;border-radius:14px;margin:10px 0;overflow:hidden;box-shadow:0 1px 8px rgba(0,0,0,0.06)}
.memory-img{width:100%;height:180px;display:block}.memory-info{padding:12px}
.memory-time{font-size:12px;color:#999;display:block}.memory-desc{font-size:15px;color:#333;display:block;margin:4px 0}
.memory-tags{display:flex;gap:6px}.tag{background:#f0f4ff;color:#1A2744;padding:2px 10px;border-radius:10px;font-size:12px}
.tag-people{background:#fef3c7;color:#92400e;padding:2px 10px;border-radius:10px;font-size:12px}
